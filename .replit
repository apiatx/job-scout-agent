modules = ["nodejs-24", "python-3.11", "postgresql-16"]


[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "nano"]

[userenv]

[userenv.shared]
GMAIL_REDIRECT_URI = "https://c12ad21f-8216-45ab-b03f-5e735925225d-00-34c2t5oabpvff.riker.replit.dev/api/gmail/callback"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true

[deployment]
build = ["sh", "-c", "pnpm --filter @workspace/api-server run build"]
run = ["sh", "-c", "PORT=8080 pnpm --filter @workspace/api-server run start"]
deploymentTarget = "cloudrun"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "lsof -ti:8080 2>/dev/null | xargs -r kill -9 2>/dev/null; sleep 0.3; cd artifacts/api-server && PORT=8080 npm run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"
