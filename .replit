modules = ["nodejs-24", "postgresql-16"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sudo pg_ctlcluster 16 main start 2>/dev/null; sudo -u postgres psql -tc \"SELECT 1 FROM pg_database WHERE datname='jobscout'\" | grep -q 1 || sudo -u postgres psql -c \"CREATE DATABASE jobscout; CREATE USER runner WITH PASSWORD 'runner'; GRANT ALL ON DATABASE jobscout TO runner;\" && sudo -u postgres psql -d jobscout -c \"GRANT ALL ON SCHEMA public TO runner;\" 2>/dev/null; cd artifacts/api-server && DATABASE_URL='postgresql://runner:runner@localhost:5432/jobscout' PORT=8080 npx tsx ./src/index.ts"
waitForPort = 8080

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
GMAIL_REDIRECT_URI = "https://c12ad21f-8216-45ab-b03f-5e735925225d-00-34c2t5oabpvff.riker.replit.dev/api/gmail/callback"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true
