modules = ["nodejs-24", "postgresql-16"]

[workflows]
runButton = "Start"

[[workflows.workflow]]
name = "Start"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f tsx || true; pkill -f node || true; sleep 1; cd artifacts/api-server && PORT=8080 npm run dev"
waitForPort = 8080

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
GMAIL_REDIRECT_URI = "https://c12ad21f-8216-45ab-b03f-5e735925225d-00-34c2t5oabpvff.riker.replit.dev/api/gmail/callback"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true
