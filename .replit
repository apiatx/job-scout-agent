modules = ["nodejs-24", "python-3.11", "postgresql-16"]


[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[userenv]

[userenv.shared]
GMAIL_REDIRECT_URI = "https://c12ad21f-8216-45ab-b03f-5e735925225d-00-34c2t5oabpvff.riker.replit.dev/api/gmail/callback"

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true

[deployment]
build = ["sh", "-c", "pnpm --filter @workspace/api-server run build"]
run = ["sh", "-c", "PORT=8080 pnpm --filter @workspace/api-server run start"]
deploymentTarget = "cloudrun"
